{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node (Express)",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": false,
    "noEmit": false,
    "types": ["node"]
  }
}

# LexDraft API - docker-compose env file.
#
# Copy this file to `.env.docker` at the repo root (it's already loaded
# by docker-compose.yml from apps/api/.env.docker). Sane defaults for
# local development with `docker compose up`. NEVER use these values
# in production - see DEPLOYMENT.md for the prod checklist.

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# JWT - replace in production with a 32+ byte random secret.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me-in-production-please-32-bytes-min
JWT_EXPIRES_IN=7d

# CORS - the web container is reachable at http://localhost:8080 from
# the host, so that's the origin the browser sends. Add additional
# comma-separated origins as you onboard staging / preview environments.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# LLM provider - keep `none` until you wire real credentials. Drafting
# falls back to the deterministic template, which is the right answer
# for local dev (no per-call cost, deterministic snapshots).
LLM_PROVIDER=none
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
XAI_API_KEY=
XAI_MODEL=grok-4

# Postgres - the `postgres` hostname resolves to the compose service.
# Local container speaks plain TCP without TLS, so DATABASE_SSL=false.
DATABASE_URL=postgresql://postgres:lexdraft@postgres:5432/lexdraft
DATABASE_SSL=false

# Storage - `local` writes to /app/uploads in the container. The volume
# in docker-compose.yml binds this to ./uploads on the host so files
# survive container rebuilds.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=/app/uploads
# Absolute URL the API is reachable at (used to mint presigned download
# URLs that the browser follows back through the API). For local dev the
# API is exposed on host:4000.
STORAGE_PUBLIC_BASE_URL=http://localhost:4000
# 32+ random bytes. Falls back to JWT_SECRET when blank; explicitly set
# in production with `openssl rand -base64 48`.
STORAGE_SIGNING_SECRET=

# Per-user write rate limit (writes per window, in ms).
WRITE_RATE_LIMIT=120
WRITE_RATE_LIMIT_WINDOW_MS=900000

# Web origin used to build magic links and similar emails. Matches the
# web container exposed on the host.
WEB_PUBLIC_BASE_URL=http://localhost:8080
CLIENT_PORTAL_RETURN_LINK=true
CLIENT_PORTAL_LINK_TTL_MIN=15
CLIENT_PORTAL_SESSION_TTL=24h

# Dev escape hatch - turns on auto-provisioning unknown emails at sign-in.
# Force OFF for any environment that isn't a local laptop.
DEV_AUTH_AUTO_PROVISION=true

# Webhook HMAC secrets - leave blank for local dev unless you're testing
# the verification path. Production rejects unsigned webhooks unless
# WEBHOOK_ALLOW_UNVERIFIED=true AND NODE_ENV != production.
WEBHOOK_SECRET_ECOURTS=
WEBHOOK_SECRET_PAYMENT=
WEBHOOK_SECRET_ESIGN=
WEBHOOK_ALLOW_UNVERIFIED=true

# Research backend. 'none' returns 501 from /api/research - keep this
# until real case-law retrieval is built. 'demo' returns a clearly
# labelled DEMONSTRATION answer for sales screenshots only.
RESEARCH_PROVIDER=none

NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# JWT — replace in production with a 32+ byte secret.
JWT_SECRET=change-me-in-production-please-32-bytes-min
JWT_EXPIRES_IN=7d

# CORS — frontend dev origin(s), comma-separated.
CORS_ORIGINS=http://localhost:5173

# LLM provider for /drafting + /research.
#   auto       — use xai if XAI_API_KEY set, else anthropic, else template
#   xai        — force Grok (xAI)
#   anthropic  — force Claude (Anthropic)
#   none       — always use the deterministic mock template
LLM_PROVIDER=auto

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# xAI Grok (optional). Get a key at https://console.x.ai/.
# Verify the exact model id at https://docs.x.ai/docs/models — current
# published ids include grok-4, grok-4-fast, grok-3. Override here if needed.
XAI_API_KEY=
XAI_MODEL=grok-4

# Postgres (Supabase) — leave DATABASE_URL blank to use the in-memory demo store.
# Use the Supabase "Session pooler" URI (port 5432). The pooler URL has the
# shape  postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:5432/postgres
DATABASE_URL=
# Set to "false" only for local Postgres without TLS (e.g. Docker compose).
DATABASE_SSL=true

# Storage — `local` keeps files on disk under STORAGE_LOCAL_DIR and serves them
# via signed URLs through this API. Switch to `s3` or `r2` once credentials are
# wired (see services/storage.service.ts).
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# Absolute URL the API is reachable at — used to build presigned URLs.
STORAGE_PUBLIC_BASE_URL=
# 32+ random bytes. Falls back to JWT_SECRET when blank.
STORAGE_SIGNING_SECRET=

# Per-user write rate limit (writes per window, in ms).
WRITE_RATE_LIMIT=120
WRITE_RATE_LIMIT_WINDOW_MS=900000

# Dev-only escape hatch. Setting this to 'true' lets an unknown email at
# sign-in auto-provision a user (and emails containing 'admin' auto-promote
# to superadmin). Convenient for local demos, fatal in production —
# automatically forced off when NODE_ENV='production'. Leave 'false' unless
# you know exactly what you're doing.
DEV_AUTH_AUTO_PROVISION=false

# Webhook HMAC-SHA256 secrets, one per :source path segment under
# /api/webhooks/:source. Each provider signs the raw request bytes with
# its secret and stamps `x-signature: sha256=<hex>`. Empty values reject
# the source with 503 unless WEBHOOK_ALLOW_UNVERIFIED='true' below.
WEBHOOK_SECRET_ECOURTS=
WEBHOOK_SECRET_PAYMENT=
WEBHOOK_SECRET_ESIGN=
# Dev-only — accept unsigned webhooks. NEVER set in production; the env
# loader forces it off when NODE_ENV='production'.
WEBHOOK_ALLOW_UNVERIFIED=false

# Research backend. 'none' returns 501 from /api/research — the right
# answer until real case-law retrieval is built. 'demo' returns a clearly-
# labelled DEMONSTRATION CONTENT canned answer (useful for sales) and
# never claims to be real legal research. NEVER ship 'demo' to paying
# customers without a UI banner warning the response is illustrative.
RESEARCH_PROVIDER=none
